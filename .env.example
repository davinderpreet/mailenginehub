# ============================================
#  MailEngineHub — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================

# ── Amazon SES (Email Sending) ──────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
DEFAULT_FROM_EMAIL=news@yourdomain.com

# ── Shopify Integration ─────────────────────
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Flask ────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=generate-a-random-secret-key-here

# ── Admin Authentication ─────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
BASE_URL=http://localhost:5000

# ── AI Engine (Anthropic Claude API) ─────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
AI_ENGINE_ENABLED=false

# ── SES Sandbox ──────────────────────────────
SES_SANDBOX_MODE=true
SES_SANDBOX_TEST_EMAIL=your-test@email.com

# ── Omnisend (Optional — legacy migration) ───
OMNISEND_API_KEY=your_omnisend_key_here
